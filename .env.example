BACKEND_URL=http://localhost:8000

# Site preview gate (Vercel only). Set BOTH to enable, leave unset to disable.
# Prompts for credentials on every page except /dashboard.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=

# Admin gate (Vercel only). Set BOTH to enable, leave unset to disable.
# Required for /dashboard. Use a DIFFERENT password than BASIC_AUTH_PASSWORD —
# coworkers can have site access without admin access.
# ADMIN_USER=
# ADMIN_PASSWORD=
