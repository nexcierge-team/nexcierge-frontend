BACKEND_URL=http://localhost:8000
# Shared secret sent as x-internal-token on every server-side call to the
# FastAPI backend. Must match the backend's BACKEND_SHARED_SECRET. Leave
# unset locally (the backend skips the check when its own secret is unset).
BACKEND_SHARED_SECRET=

# Supabase (required). See frontend/supabase/README.md for setup.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS, used for ai/system message inserts.
# Never prefix with NEXT_PUBLIC_, never log, never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# HubSpot (required once Step 5 is enabled). Get from a Private App
# in HubSpot Settings → Integrations → Private Apps with scopes:
#   crm.objects.contacts.read/write
#   crm.objects.deals.read/write
#   crm.schemas.deals.read
#   crm.objects.owners.read
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_PIPELINE_ID=
HUBSPOT_DEALSTAGE_NEW=
# Stage id for "Assigned to Account Manager". When an AM claims a
# brief, the linked deal auto-advances to this stage. Leave unset to
# skip the auto-advance.
HUBSPOT_DEALSTAGE_ASSIGNED_TO_AM=
HUBSPOT_DEFAULT_OWNER_ID=
# Feature flag — set to false to skip HubSpot on handoff. Useful for
# local dev so test handoffs don't pollute production CRM.
HUBSPOT_ENABLED=false

# Optional: HTTP Basic Auth gate (set BOTH to enable, leave unset to disable).
# Used for pre-launch private previews on Vercel. Don't set in local dev.
# Auth callback paths (/auth/* and /api/auth/*) are always exempt.
# BASIC_AUTH_USER=
# BASIC_AUTH_PASSWORD=
